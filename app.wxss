page {
  --primary: #1a73e8;
  --primary-light: #e8f0fe;
  --success: #34a853;
  --warning: #f9ab00;
  --danger: #ea4335;
  --info: #4285f4;
  --gray-100: #f8f9fa;
  --gray-200: #e9ecef;
  --gray-300: #dee2e6;
  --gray-500: #6c757d;
  --gray-700: #495057;
  --gray-900: #212529;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  background-color: #f5f6fa;
  color: var(--gray-900);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 20rpx;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 广告区域 */
.ad-section {
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
  min-height: 0;
}

/* 激励视频解锁区域 */
.suggestion-locked {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 0;
}

.locked-text {
  font-size: 28rpx;
  color: #888;
}

.unlock-btn {
  background: linear-gradient(135deg, #f9ab00, #ff8f00);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 18rpx 60rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(249,171,0,0.3);
}

.unlock-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}
