.page-school-detail {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 60rpx;
}

.school-hero {
  position: relative;
  padding: 48rpx 32rpx 40rpx;
  overflow: hidden;
}

.page-school-detail .school-hero {
  padding-top: 48rpx;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #1a73e8 0%, #4285f4 100%);
}

.hero-body {
  position: relative;
  z-index: 1;
}

.school-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

.school-address {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.prob-display {
  margin-top: 20rpx;
}

/* 对比卡片 */
.compare-card {
  margin: -20rpx 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 2;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.cat-note {
  background: #fff3e0;
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
}

.cat-note text {
  font-size: 24rpx;
  color: #e65100;
  font-weight: 500;
}

.compare-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.compare-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compare-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.compare-score {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.user-score {
  color: #1a73e8;
}

.school-score {
  color: #555;
}

.compare-vs {
  font-size: 28rpx;
  color: #ccc;
  font-weight: 700;
  margin: 0 16rpx;
}

.compare-diff {
  text-align: center;
  margin-top: 20rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.diff-positive {
  background: #e6f4ea;
  color: #34a853;
}

.diff-negative {
  background: #fce8e6;
  color: #ea4335;
}

/* 图表 */
.chart-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.chart-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 16rpx;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-line {
  width: 32rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.legend-line.dashed {
  background: repeating-linear-gradient(
    90deg,
    #ea4335 0,
    #ea4335 8rpx,
    transparent 8rpx,
    transparent 14rpx
  ) !important;
}

.legend-item text {
  font-size: 22rpx;
  color: #888;
}

/* 数据表 */
.data-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.data-table {
  border-radius: 12rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  padding: 16rpx 0;
  background: #f8f9fa;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.table-header text {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

.table-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.table-row:last-child {
  border-bottom: none;
}

.col-year {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
}

.col-score {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
}

.col-diff {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}

.text-success {
  color: #34a853;
}

.text-danger {
  color: #ea4335;
}

/* 分析 */
.analysis-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.analysis-body {
  display: flex;
  flex-direction: column;
}

.analysis-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.analysis-item:last-child {
  border-bottom: none;
}

.analysis-label {
  font-size: 28rpx;
  color: #666;
}

.analysis-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 建议 */
.suggestion-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.suggestion-body {
  background: #f0f7ff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.suggestion-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}
