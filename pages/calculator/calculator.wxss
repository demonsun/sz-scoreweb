.page-calculator {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
}

.calc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.header-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.back-arrow {
  font-size: 56rpx;
  color: #1a73e8;
  font-weight: 300;
  line-height: 1;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.header-right {
  width: 80rpx;
  display: flex;
  justify-content: flex-end;
}

.reset-btn {
  font-size: 26rpx;
  color: #ea4335;
}

.progress-section {
  padding: 24rpx 40rpx 16rpx;
  background: #fff;
}

.question-swiper {
  flex: 1;
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.swiper-content {
  padding: 8rpx 0;
}

.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
}

.btn-prev, .btn-next, .btn-submit {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-prev {
  background: #f0f0f0;
  color: #666;
}

.btn-prev:active {
  background: #e0e0e0;
}

.btn-next {
  background: #1a73e8;
  color: #fff;
}

.btn-next:active {
  opacity: 0.85;
}

.btn-submit {
  background: linear-gradient(135deg, #34a853, #1a73e8);
  color: #fff;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.step-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 0 32rpx 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.2s;
}

.dot-active {
  background: #1a73e8;
  transform: scale(1.3);
}

.dot-answered {
  background: #a8d5a2;
}

.dot-active.dot-answered {
  background: #1a73e8;
}
