.gauge-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.gauge-ring {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gauge-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0f4ff;
}

.gauge-canvas {
  position: absolute;
  top: 0;
  left: 0;
}

.gauge-value-wrap {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gauge-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #1a73e8;
  line-height: 1;
}

.gauge-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.gauge-category {
  margin-top: 24rpx;
}

.category-badge {
  display: inline-block;
  padding: 8rpx 32rpx;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.gauge-breakdown {
  width: 100%;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #eee;
}

.breakdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.breakdown-label {
  font-size: 28rpx;
  color: #666;
}

.breakdown-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a73e8;
}
